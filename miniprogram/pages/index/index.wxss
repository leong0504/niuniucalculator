.page {
  min-height: 100vh;
  background: #07090d;
  color: #f2f3f6;
  display: flex;
  flex-direction: column;
}

.cards {
  margin-top: 26rpx;
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  perspective: 900rpx;
}

.card {
  width: calc((100% - 48rpx) / 5);
  height: 190rpx;
  border-radius: 12rpx;
  border: 1px solid #d8d8db;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 66rpx;
  font-weight: 600;
  background: #f3f3f5;
  color: #bc3837;
  backface-visibility: hidden;
}

.card-flip-in {
  animation: cardFlipIn 0.42s ease-out;
}

@keyframes cardFlipIn {
  0% {
    transform: rotateY(90deg) scale(0.96);
    opacity: 0.35;
  }
  60% {
    transform: rotateY(-8deg) scale(1.02);
    opacity: 1;
  }
  100% {
    transform: rotateY(0deg) scale(1);
    opacity: 1;
  }
}

.card.empty {
  background: transparent;
  border-color: transparent;
  color: transparent;
}

.card-back {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  background: #ffffff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-back-image {
  width: 100%;
  height: 100%;
}

.top {
  padding: 36rpx 20rpx 0;
}

.nav-title {
  text-align: center;
  font-size: 42rpx;
  font-weight: 600;
}

.result-main {
  margin-top: 24rpx;
  text-align: center;
  color: #ff7984;
  font-size: 76rpx;
  font-weight: 700;
}

.picked {
  margin-top: 18rpx;
  text-align: center;
  color: #7f8999;
  font-size: 22rpx;
}

.kb-wrap {
  margin-top: auto;
  width: 100%;
  background: transparent;
}

.kb {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  padding: 0 8rpx 8rpx;
  box-sizing: border-box;
}

.key {
  background: #333434;
  color: #ffffff;
  border-radius: 28rpx;
  font-size: 56rpx;
  font-weight: 500;
  height: 162rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.key.special {
  color: #ffffff;
}

.key.action {
  background: #f18a30;
  color: #ffffff;
  font-size: 68rpx;
}
